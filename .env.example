# ─── Ground Control — Znuny dev stack ───────────────────────────────
# Copy to .env and adjust. This file IS committed (placeholder values).

COMPOSE_PROJECT_NAME=ground-control

# ─── Znuny ──────────────────────────────────────────────────────────
ZNUNY_VERSION=7.2.3
ZNUNY_FQDN=znuny-dev.was.dev.br
ZNUNY_SYSTEM_ID=10
ZNUNY_HTTP_PORT=8080
# Seeded super-admin (Znuny agent "root@localhost" is the built-in;
# we (re)set its password to this deterministically on provision).
ZNUNY_ADMIN_USER=root@localhost
ZNUNY_ADMIN_PASSWORD=Admin-Change-Me-123

# ─── PostgreSQL ─────────────────────────────────────────────────────
# Image tag: postgres:18 (primary) — falls back to postgres:17 only if
# documented in docs/decisions/0001-stack.md. See README "PG18 verdict".
POSTGRES_IMAGE=postgres:18
POSTGRES_DB=znuny
POSTGRES_USER=znuny
POSTGRES_PASSWORD=znuny-db-pass-change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── OpenSearch ─────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
# OpenSearch 2.x requires a strong admin password for the demo security
OPENSEARCH_INITIAL_ADMIN_PASSWORD=OpenSearch-Str0ng-Pass!
