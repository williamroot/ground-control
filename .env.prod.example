# ─── Production-only secrets — copy to .env.prod (gitignored) ───────
# The Cloudflare Tunnel token is NOT available yet. When the user
# provisions the tunnel in the Cloudflare dashboard for hostname
# znuny-dev.was.dev.br, paste the connector token here.
#
# Until then cloudflared starts and logs an auth error — that is
# expected and does NOT fail the stack (see README troubleshooting).

CLOUDFLARE_TUNNEL_TOKEN=replace-with-real-cloudflared-connector-token

# ─── Gerti sidecar DB credentials (single-cluster, schema `gerti`) ───
# Used by docker-compose profile `gerti` (gerti-db-init / sidecar-migrate
# / sidecar). See docs/superpowers/plans/2026-05-17-spec-1c-deploy.md.
# Generate strong values; NEVER commit the real .env.prod.
GERTI_SIDECAR_DB_PASSWORD=replace-with-strong-secret
GERTI_ADMIN_DB_PASSWORD=replace-with-strong-secret
GERTI_SIDECAR_VERSION=dev

# ─── Portal session secret (#1F-a/#1H) ──────────────────────────────
# HS256 signing key for the portal `gsid` AND admin `gsid_adm` cookies.
# Strong (32+ bytes hex). Boot fails in prod if left default.
GERTI_SESSION_SECRET=replace-with-strong-32byte-hex

# ─── Znuny Generic Interface — auth + admin write (#1F-a/#1G-a) ──────
# GertiCustomerAuth webservice (D14, customer login) and the GertiAdmin
# webservice (D19, onboarding write: CustomerCompany/User/SetPassword).
# Both reuse the SAME AccessToken (ZNUNY_WS_TOKEN ↔ Znuny cfg key
# GertiAdmin::AccessToken). The admin URL is the base up to and including
# .../Webservice/GertiAdmin. NEVER commit the real .env.prod.
ZNUNY_WS_URL=https://znuny-dev.was.dev.br/znuny/nph-genericinterface.pl/Webservice/GertiCustomerAuth/Session
ZNUNY_ADMIN_WS_URL=https://znuny-dev.was.dev.br/znuny/nph-genericinterface.pl/Webservice/GertiAdmin
ZNUNY_WS_TOKEN=replace-with-webservice-access-token

# Separate, more-powerful AccessToken for the agent ops (#1J): the 3 GertiAgent
# ops (TimeAccountingAdd/AgentTicketSearch/AgentTicketGet → root UserID=>1,
# cross-tenant, internal articles) use their own token (Znuny cfg key
# GertiAgent::AccessToken) so a customer-flow token leak can't reach them.
ZNUNY_AGENT_WS_TOKEN=replace-with-agent-webservice-access-token

# Console de Administração (#1G-a) UI image tag.
GERTI_ADMIN_UI_VERSION=dev

# ─── Contratação self-service + Asaas (Spec #2) ─────────────────────
# Opt-in: com ASAAS_ENABLED=false (ou key vazia) o checkout responde 404
# (fail-safe). Conta Gerti default abaixo; contas de MSP (multi-conta) ficam
# em gerti.payment_provider_account com api_key_ref → env var (fase 3).
# SANDBOX primeiro: https://api-sandbox.asaas.com/v3 ; prod: https://api.asaas.com/v3
ASAAS_ENABLED=false
ASAAS_API_KEY=replace-with-asaas-api-key
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Token do webhook (header asaas-access-token) — gerar forte e cadastrar no Asaas.
ASAAS_WEBHOOK_TOKEN=replace-with-strong-webhook-token
ASAAS_TIMEOUT_SECONDS=30
# Base pública do app de checkout (monta links/redirects).
CHECKOUT_PUBLIC_BASE_URL=https://contratar.was.dev.br
# Tag de imagem do app de checkout.
GERTI_CHECKOUT_UI_VERSION=dev
